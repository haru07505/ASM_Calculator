@echo off

echo ADD:
calculator.exe 1250 + 320

echo SUB:
calculator.exe 1250 - 320

echo MUL:
calculator.exe 1250 * 200

echo DIV:
calculator.exe 1250 / 200

echo MOD:
calculator.exe 1000 %% 300

echo NEGATE:
calculator.exe 1250 n 0

echo SQUARE:
calculator.exe 500 s 0

echo RECIPROCAL:
calculator.exe 200 r 0

echo DIV ZERO:
calculator.exe 1250 / 0

pause